# Copy to .env.deploy and fill in (never commit .env.deploy)
# Run: bun run deploy

# --- SSH (use key OR password) ---
DEPLOY_SSH_HOST=your.vps.ip.or.hostname
DEPLOY_SSH_PORT=22
DEPLOY_SSH_USER=root
# Preferred: path to private key
DEPLOY_SSH_KEY_PATH=/home/you/.ssh/id_ed25519
# DEPLOY_SSH_KEY_PASSPHRASE=

# Alternative if you must use password (less safe)
# DEPLOY_SSH_PASSWORD=

# --- App / domains (hostname only: no https://, no path — typo jehan.my/id breaks nginx) ---
DEPLOY_REMOTE_DIR=/opt/tiktok-scraper
DEPLOY_DOMAIN_WEB=scraper.example.com
DEPLOY_DOMAIN_API=api-scraper.example.com
DEPLOY_JWT_SECRET=use-a-long-random-secret

# Public API URL as seen by the browser (must match TLS/DNS). Default: https://DEPLOY_DOMAIN_API
# DEPLOY_API_PUBLIC_URL=https://api-scraper.example.com
