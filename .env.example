# ================================================
# TikTok Scraper - Environment Configuration
# ================================================
# Copy this file to .env and fill in the values

# JWT Secret (CHANGE THIS in production!)
JWT_SECRET=your-super-secret-jwt-key-change-me

# Frontend → API base URL (must be reachable from the browser, not Docker service names)
# Local bun dev (api :3000): http://localhost:3000
# Local full Docker (compose publishes api :5000): use `bun run docker:local` or set http://localhost:5000 and rebuild web
# VPS: http://YOUR_PUBLIC_IP:5000 or https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:3000

# ================================================
# If running WITHOUT Docker, also set these:
# ================================================

# Database
# DATABASE_URL=postgres://tiktok:tiktok_secret@localhost:5432/tiktok_scraper

# Redis
# REDIS_URL=redis://localhost:6379
