    "@resvg/resvg-js": "^2.6.2",
    "bullmq": "^5.73.3",
    "dotenv": "^17.4.1",
    "drizzle-orm": "^0.45.2",
    "elysia": "^1.4.28",
    "ioredis": "^5.10.1",
    "postgres": "^3.4.9",
    "satori": "^0.26.0"
